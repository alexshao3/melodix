###############################################################################
# Melodix — Production Environment Variables
#
# Copy this file to .env.production and fill in your values:
#   cp .env.production.example .env.production
#
# Then run:
#   docker compose --env-file .env.production up -d --build
###############################################################################

# ── Required ─────────────────────────────────────────────────────────

# JWT secret for auth tokens (generate with: openssl rand -base64 32)
JWT_SECRET=change-me-in-production-please

# Cloudflare Tunnel token (from https://one.dash.cloudflare.com → Networks → Tunnels)
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here

# ── Database ─────────────────────────────────────────────────────────
# Local Postgres is enabled by default in docker-compose.yml. The defaults
# below match the bundled `postgres` service. Override with a cloud URL
# (Supabase, Neon, Railway, …) if you remove that service.
POSTGRES_USER=melodix
POSTGRES_PASSWORD=melodix
POSTGRES_DB=melodix
DATABASE_URL=postgresql://melodix:melodix@postgres:5432/melodix?schema=public

# ── Redis ────────────────────────────────────────────────────────────
# Local Redis is enabled by default in docker-compose.yml. The default
# below matches the bundled `redis` service. Override with a cloud URL
# (Upstash, Redis Cloud, Railway, …) if you remove that service.
REDIS_URL=redis://redis:6379

# ── API URL (IMPORTANT for client-side routing) ─────────────────────
# This is baked into the Next.js client bundle at build time.
# Set it to the public URL where your API will be reachable via Cloudflare Tunnel.
#
# Example: if you set api.melodix.yourdomain.com → http://api:4000 in Cloudflare
NEXT_PUBLIC_API_URL=https://api.melodix.yourdomain.com

# CORS origins for the API (comma-separated, or * for all)
CORS_ORIGIN=https://melodix.yourdomain.com,https://app.melodix.yourdomain.com

# ── Optional ─────────────────────────────────────────────────────────

# Jamendo API key for live music catalog (app works without it using demo tracks)
# Register at https://devportal.jamendo.com
JAMENDO_CLIENT_ID=

# Telegram Bot token for Mini App auth verification
# Create a bot via https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# ── Storage backend ──────────────────────────────────────────────────
# Choose where uploaded audio + cover files live. See ADR-0026.
#   - `s3`       (default) → upload to any S3-compatible bucket (Backblaze
#                            B2, Cloudflare R2, Storj, MinIO, AWS S3…).
#                            Set the S3_* vars below.
#   - `postgres`            → store blobs as `bytea` in the same Postgres
#                            database, served via /api/storage/<key> with
#                            HTTP Range support. Set API_PUBLIC_URL below.
#                            Best with self-hosted Postgres (DB ≈ library
#                            size); cloud free tiers (Neon 0.5 GB) are
#                            usually too small.
STORAGE_BACKEND=s3

# ── S3-compatible storage (used when STORAGE_BACKEND=s3) ─────────────
# Defaults shown are for Backblaze B2 (10 GB free, no card required).
# The same env vars work for any S3-compatible provider — just swap the
# endpoint/region/public URL (Cloudflare R2, Storj, MinIO, AWS S3…).
#
# Backblaze B2 setup:
#   1. Sign up: https://www.backblaze.com/sign-up/cloud-storage  (email only)
#   2. Create a bucket → Buckets → Create a Bucket  (set "Public" if you
#      want direct hotlinking; "Private" if you'll proxy via the API)
#   3. Application Keys → Add a New Application Key, scope to that bucket
#      and copy the keyID + applicationKey
#   4. Note the bucket's S3 Endpoint shown in the bucket details, e.g.
#      `s3.us-west-004.backblazeb2.com` — the region is the middle segment
#      (`us-west-004`) and the full endpoint is `https://<that host>`.
S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
S3_REGION=us-west-004
S3_ACCESS_KEY_ID=your-b2-key-id
S3_SECRET_ACCESS_KEY=your-b2-application-key
S3_BUCKET=melodix
# Public URL for objects in the bucket. For a Public B2 bucket, this is
# `https://f<cluster>.backblazeb2.com/file/<bucket-name>` (cluster shown in
# the B2 web UI under "Friendly URL"). For a Private bucket, leave empty
# and serve via the API or a CDN in front.
S3_PUBLIC_URL=https://f004.backblazeb2.com/file/melodix
# Optional: force path-style URLs ('true' or 'false'; rarely needed).
S3_FORCE_PATH_STYLE=false

# ── Postgres-blob storage (used when STORAGE_BACKEND=postgres) ───────
# Public base URL of the API as reachable from the user's browser. Upload
# URLs become `${API_PUBLIC_URL}/api/storage/<folder>/<filename>`, so this
# must match the address you exposed via Cloudflare Tunnel (or whichever
# reverse proxy fronts the API). For local docker-compose tests with the
# api published on :4000, you can set `http://localhost:4000`.
API_PUBLIC_URL=https://api.melodix.yourdomain.com
