# Database
DATABASE_URL="postgresql://melodix:melodix@localhost:5432/melodix?schema=public"

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# JWT
JWT_SECRET=change-me-in-production-please
JWT_EXPIRES_IN=30d

# Jamendo (free music API; register at https://devportal.jamendo.com)
JAMENDO_CLIENT_ID=

# Telegram (for /api/auth/telegram verification)
TELEGRAM_BOT_TOKEN=

# S3-compatible storage for admin track uploads (Backblaze B2 by default).
# Required only if you use the admin upload feature. See
# .env.production.example at repo root for full setup notes.
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=melodix
S3_PUBLIC_URL=
S3_FORCE_PATH_STYLE=false
