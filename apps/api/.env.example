# Database
DATABASE_URL="postgresql://melodix:melodix@localhost:5432/melodix?schema=public"

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# JWT
JWT_SECRET=change-me-in-production-please
JWT_EXPIRES_IN=30d

# Jamendo (free music API; register at https://devportal.jamendo.com)
JAMENDO_CLIENT_ID=

# Telegram (for /api/auth/telegram verification)
TELEGRAM_BOT_TOKEN=

# Storage backend selector for admin track uploads. See ADR-0026.
#   - `s3`       (default) → upload to any S3-compatible bucket (Backblaze
#                            B2, Cloudflare R2, Storj, MinIO, AWS S3…).
#   - `postgres`            → store blobs as `bytea` in the same Postgres
#                            database, served via /api/storage/<key>.
STORAGE_BACKEND=s3

# S3-compatible storage (used when STORAGE_BACKEND=s3; Backblaze B2 by default).
# Required only if you use the admin upload feature. See
# .env.production.example at repo root for full setup notes.
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=melodix
S3_PUBLIC_URL=
S3_FORCE_PATH_STYLE=false

# Postgres-blob storage (used when STORAGE_BACKEND=postgres).
# Optional. Leave empty to store relative URLs (`/api/storage/<key>`) —
# the web/miniapp/admin Next.js servers proxy these to the API at runtime
# (ADR-0029). Set to an absolute URL only if you want upload URLs to
# point at a separate public hostname, e.g. a CDN in front of the API:
# API_PUBLIC_URL=https://api.melodix.yourdomain.com
API_PUBLIC_URL=

# Aeneas forced-aligner sidecar URL — used by the
# POST /api/admin/tracks/:id/auto-sync-lyrics endpoint to generate LRC
# timestamps for upload-source tracks. Default works inside docker-compose.
AENEAS_URL=http://aeneas:8000
