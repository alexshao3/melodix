generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String?  @unique
  username    String   @unique
  password    String?
  displayName String?
  avatar      String?
  telegramId  String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  playlists Playlist[]
  likes     Like[]
  history   PlayHistory[]
  follows   Follow[]

  @@map("users")
}

/**
 * Artist follow log. Like `PlayHistory.trackId`, `artistId` is a free string
 * (`jm_<jamendoId>` in practice) rather than a FK on Artist — Artists are
 * persisted lazily and the follow surface must work for any Jamendo id.
 * See ADR-0016.
 */
model Follow {
  userId    String
  artistId  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, artistId])
  @@index([userId, createdAt])
  @@map("follows")
}

/**
 * Server-side "recently played" log. We deliberately store `trackId` as a
 * free string (typically `jm_<jamendoId>`) rather than as a FK on Track —
 * Tracks are only persisted lazily and the play log must work for any
 * Jamendo id the player decides to render. See ADR-0014.
 */
model PlayHistory {
  id       String   @id @default(cuid())
  userId   String
  trackId  String
  playedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, playedAt])
  @@map("play_history")
}

model Artist {
  id         String   @id @default(cuid())
  externalId String?  @unique
  name       String
  image      String?
  bio        String?
  followers  Int      @default(0)
  source     String   @default("jamendo")
  createdAt  DateTime @default(now())

  albums Album[]
  tracks Track[]

  @@index([name])
  @@map("artists")
}

model Album {
  id          String   @id @default(cuid())
  externalId  String?  @unique
  name        String
  cover       String?
  releaseDate String?
  artistId    String
  source      String   @default("jamendo")
  createdAt   DateTime @default(now())

  artist Artist  @relation(fields: [artistId], references: [id], onDelete: Cascade)
  tracks Track[]

  @@index([name])
  @@index([artistId])
  @@map("albums")
}

model Track {
  id          String   @id @default(cuid())
  externalId  String?  @unique
  title       String
  duration    Int
  audioUrl    String
  streamUrl   String?
  cover       String?
  genre       String?
  releaseDate String?
  source      String   @default("jamendo")
  artistId    String
  albumId     String?
  createdAt   DateTime @default(now())

  artist          Artist           @relation(fields: [artistId], references: [id], onDelete: Cascade)
  album           Album?           @relation(fields: [albumId], references: [id], onDelete: SetNull)
  playlistTracks  PlaylistTrack[]

  @@index([title])
  @@index([artistId])
  @@index([albumId])
  @@index([genre])
  @@map("tracks")
}

model Playlist {
  id          String   @id @default(cuid())
  name        String
  description String?
  cover       String?
  isPublic    Boolean  @default(true)
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner  User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tracks PlaylistTrack[]

  @@index([ownerId])
  @@map("playlists")
}

model PlaylistTrack {
  id         String   @id @default(cuid())
  playlistId String
  trackId    String
  position   Int
  addedAt    DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track    Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([playlistId, trackId])
  @@index([playlistId, position])
  @@map("playlist_tracks")
}

/**
 * Track like log. `trackId` is a free string (`jm_<jamendoId>` in practice)
 * rather than a FK on Track — Tracks are persisted lazily and the like
 * surface must work for any Jamendo / demo id without round-tripping the
 * track first. Mirrors `PlayHistory` (ADR-0014) and `Follow` (ADR-0016).
 */
model Like {
  id        String   @id @default(cuid())
  userId    String
  trackId   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
  @@index([userId])
  @@map("likes")
}
