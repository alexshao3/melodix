generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String?  @unique
  username    String   @unique
  password    String?
  displayName String?
  avatar      String?
  telegramId  String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  playlists Playlist[]
  likes     Like[]
  history   PlayHistory[]
  follows   Follow[]

  @@map("users")
}

/**
 * Artist follow log. Like `PlayHistory.trackId`, `artistId` is a free string
 * (`jm_<jamendoId>` in practice) rather than a FK on Artist — Artists are
 * persisted lazily and the follow surface must work for any Jamendo id.
 * See ADR-0016.
 */
model Follow {
  userId    String
  artistId  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, artistId])
  @@index([userId, createdAt])
  @@map("follows")
}

/**
 * Server-side "recently played" log. We deliberately store `trackId` as a
 * free string (typically `jm_<jamendoId>`) rather than as a FK on Track —
 * Tracks are only persisted lazily and the play log must work for any
 * Jamendo id the player decides to render. See ADR-0014.
 */
model PlayHistory {
  id       String   @id @default(cuid())
  userId   String
  trackId  String
  playedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, playedAt])
  @@map("play_history")
}

model Artist {
  id         String   @id @default(cuid())
  externalId String?  @unique
  name       String
  image      String?
  bio        String?
  followers  Int      @default(0)
  source     String   @default("jamendo")
  createdAt  DateTime @default(now())

  albums Album[]
  tracks Track[]

  @@index([name])
  @@map("artists")
}

model Album {
  id          String   @id @default(cuid())
  externalId  String?  @unique
  name        String
  cover       String?
  releaseDate String?
  artistId    String
  source      String   @default("jamendo")
  createdAt   DateTime @default(now())

  artist Artist  @relation(fields: [artistId], references: [id], onDelete: Cascade)
  tracks Track[]

  @@index([name])
  @@index([artistId])
  @@map("albums")
}

model Track {
  id          String   @id @default(cuid())
  externalId  String?  @unique
  title       String
  duration    Int
  audioUrl    String
  streamUrl   String?
  cover       String?
  genre       String?
  releaseDate String?
  source      String   @default("jamendo")
  // Pre-computed waveform peaks (~200 normalized samples in [0,1]).
  // Generated client-side at upload via OfflineAudioContext; null for
  // Jamendo / demo tracks that have no underlying audio buffer to decode.
  peaks       Json?
  // Plain-text lyrics for upload-source tracks (Creative Commons / SUNO AI / etc.).
  // Jamendo and demo tracks fetch lyrics on demand via LyricsService instead.
  lyrics      String?
  // Time-synced lyrics in standard LRC format ([mm:ss.xx] line prefixes).
  // Generated by the Aeneas forced-aligner sidecar from `lyrics` + `audioUrl`.
  // Player highlights the active line at runtime when this is non-null.
  // See ADR-0030.
  syncedLyrics String?
  // When the syncedLyrics column was last (re-)generated by the aligner.
  // Nullable while plain `lyrics` exists but no alignment has been run yet.
  lyricsAlignedAt DateTime?
  artistId    String
  albumId     String?
  createdAt   DateTime @default(now())

  artist          Artist           @relation(fields: [artistId], references: [id], onDelete: Cascade)
  album           Album?           @relation(fields: [albumId], references: [id], onDelete: SetNull)
  playlistTracks  PlaylistTrack[]

  @@index([title])
  @@index([artistId])
  @@index([albumId])
  @@index([genre])
  @@map("tracks")
}

model Playlist {
  id          String   @id @default(cuid())
  name        String
  description String?
  cover       String?
  isPublic    Boolean  @default(true)
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner  User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tracks PlaylistTrack[]

  @@index([ownerId])
  @@map("playlists")
}

model PlaylistTrack {
  id         String   @id @default(cuid())
  playlistId String
  trackId    String
  position   Int
  addedAt    DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track    Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([playlistId, trackId])
  @@index([playlistId, position])
  @@map("playlist_tracks")
}

/**
 * Track like log. `trackId` is a free string (`jm_<jamendoId>` in practice)
 * rather than a FK on Track — Tracks are persisted lazily and the like
 * surface must work for any Jamendo / demo id without round-tripping the
 * track first. Mirrors `PlayHistory` (ADR-0014) and `Follow` (ADR-0016).
 */
model Like {
  id        String   @id @default(cuid())
  userId    String
  trackId   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
  @@index([userId])
  @@map("likes")
}

// ── Admin ──────────────────────────────────────────────────────────

model AdminUser {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())

  @@map("admin_users")
}

model MusicSource {
  name     String  @id
  enabled  Boolean @default(true)
  priority Int     @default(0)

  @@map("music_sources")
}

/// Database-blob storage for uploaded audio + cover files. Used when
/// `STORAGE_BACKEND=postgres` (see ADR-0026). Keys take the form
/// `<folder>/<uuid>.<ext>` (e.g. `tracks/abc123.mp3`). The bytes column
/// is TOAST-stored so range reads via `substring(bytes from … for …)`
/// only fetch the chunks they need — see StorageController.
model StorageObject {
  key       String   @id
  folder    String
  filename  String
  mimeType  String
  size      Int
  bytes     Bytes
  createdAt DateTime @default(now())

  @@index([folder, createdAt])
  @@map("storage_objects")
}
